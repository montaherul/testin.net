@model school_management_system.Models.Teacher

@{
    ViewData["Title"] = "TeacherProfile";
}

<div class="container mt-4">

    <div class="card shadow-lg p-4">

        <div class="row">

            <!-- Teacher Photo -->
            <div class="col-md-4 text-center">

                @if (!string.IsNullOrEmpty(Model.PhotoPath))
                {
                    <img src="@Model.PhotoPath"
                         class="img-fluid rounded-circle shadow"
                         style="width:180px;height:180px;object-fit:cover;">
                }
                else
                {
                    <img src="/images/teachers/default.png"
                         class="img-fluid rounded-circle"
                         style="width:180px;height:180px;">
                }

                <h4 class="mt-3">@Model.FirstName @Model.LastName</h4>
                <p class="text-muted">Teacher</p>

                <a asp-action="Edit" asp-route-id="@Model.TeacherID"
                       class="btn btn-primary btn-sm">
                    Edit Profile
                </a>

            </div>

            <!-- Teacher Info -->
            <div class="col-md-8">

                <h4 class="mb-3">Teacher Information</h4>

                <table class="table table-bordered">

                    <tr>
                        <th>First Name</th>
                        <td>@Model.FirstName</td>
                    </tr>

                    <tr>
                        <th>Last Name</th>
                        <td>@Model.LastName</td>
                    </tr>

                    <tr>
                        <th>Email</th>
                        <td>@Model.Email</td>
                    </tr>

                    <tr>
                        <th>Phone</th>
                        <td>@Model.Phone</td>
                    </tr>

                    <tr>
                        <th>Address</th>
                        <td>@Model.Address</td>
                    </tr>

                    <tr>
                        <th>Hire Date</th>
                        <td>@Model.HireDate.ToString("dd MMM yyyy")</td>
                    </tr>

                </table>

            </div>

        </div>

    </div>


    <!-- Dashboard Cards -->

    <div class="row mt-4">

        <div class="col-md-3">
            <div class="card text-center shadow-sm p-3">
                <h5>Classes</h5>
                <h3>0</h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-center shadow-sm p-3">
                <h5>Students</h5>
                <h3>0</h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-center shadow-sm p-3">
                <h5>Subjects</h5>
                <h3>0</h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-center shadow-sm p-3">
                <h5>Attendance</h5>
                <h3>95%</h3>
            </div>
        </div>

    </div>

</div>