<h2>Attendance Dashboard</h2>

<div class="card p-3">

    <h4>Total Attendance Records</h4>

    <h2>@ViewBag.Total</h2>

    <a asp-action="MarkAttendance" class="btn btn-primary">
        Mark Attendance
    </a>

    <a asp-action="MonthlyAttendance" class="btn btn-success">
        View Monthly Report
    </a>



    </div>



    <h2>Attendance Dashboard</h2>

    <div class="row">

        <div class="col-md-3">
            <div class="card bg-primary text-white p-3">
                <h4>Total Students</h4>
                <h2>@ViewBag.TotalStudents</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-success text-white p-3">
                <h4>Present Today</h4>
                <h2>@ViewBag.Present</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-danger text-white p-3">
                <h4>Absent Today</h4>
                <h2>@ViewBag.Absent</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card bg-warning text-white p-3">
                <h4>Late</h4>
                <h2>@ViewBag.Late</h2>
            </div>
        </div>

    </div>
