@{
    ViewBag.Title = "Login";
}

<h2>Login</h2>

<form method="post">

    <div>
        <label>Username</label>
        <input type="text" name="username" required />
    </div>

    <div>
        <label>Password</label>
        <input type="password" name="password" required />
    </div>

    <button type="submit">Login</button>

    <p style="color:red">@ViewBag.Error</p>

</form>