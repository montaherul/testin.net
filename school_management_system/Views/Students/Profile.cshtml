@model school_management_system.Models.Student

@{
    ViewData["Title"] = "Student Profile";
}
@using System.Linq

<div class="container mt-4">

    <h2 class="mb-4">Student Dashboard</h2>

    <div class="row">

        <!-- Student Profile Card -->
        <div class="col-md-4">

            <div class="card text-center shadow">

                <div class="card-body">

                    @if (!string.IsNullOrEmpty(Model.PhotoPath))
                    {
                        <img src="@Model.PhotoPath"
                             width="120"
                             height="120"
                             style="border-radius:50%; object-fit:cover;" />
                    }
                    else
                    {
                        <img src="/images/students/default.png"
                             width="120"
                             height="120" />
                    }

                    <h4 class="mt-3">
                        @Model.FirstName @Model.LastName
                    </h4>

                    <p class="text-muted">
                        Admission: @Model.AdmissionNumber
                    </p>

                    <p>
                        Class:
                        @Model.Class?.ClassName -
                        @Model.Section?.SectionName
                    </p>

                    <span class="badge bg-success">
                        @Model.Status
                    </span>

                </div>

<script>
    document.addEventListener('DOMContentLoaded', function(){
        var showMore = document.getElementById('showMoreExams');
        if(showMore){
            showMore.addEventListener('click', function(e){
                e.preventDefault();
                // simple expand: reveal all list items
                var ul = this.closest('ul');
                // reload the page with no truncation could be implemented server-side; for now just hide the link
                this.style.display = 'none';
                // optionally you could request full list by AJAX; left as-is
            });
        }
    });
</script>

            </div>

        </div>

        <!-- Personal Information -->
        <div class="col-md-8">

            <div class="card shadow mb-3">

                <div class="card-header bg-primary text-white">
                    Personal Information
                </div>

                <div class="card-body">

                    <div class="row">

                        <div class="col-md-6">
                            <strong>Date of Birth</strong><br />
                            @Model.DateOfBirth.ToString("dd MMM yyyy")
                        </div>

                        <div class="col-md-6">
                            <strong>Gender</strong><br />
                            @Model.Gender
                        </div>

                        <div class="col-md-12 mt-3">
                            <strong>Address</strong><br />
                            @Model.Address
                        </div>

                    </div>

                </div>

            </div>

            <!-- Parent Information -->
            <div class="card shadow mb-3">

                <div class="card-header bg-success text-white">
                    Parent Information
                </div>

                <div class="card-body">

                    <div class="row">

                        <div class="col-md-6">
                            <strong>Parent Name</strong><br />
                            @Model.ParentName
                        </div>

                        <div class="col-md-6">
                            <strong>Phone</strong><br />
                            @Model.ParentPhone
                        </div>

                        <div class="col-md-12 mt-3">
                            <strong>Email</strong><br />
                            @Model.ParentEmail
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- Quick Actions -->
    <div class="card shadow mt-3">

        <div class="card-header bg-dark text-white">
            Quick Actions
        </div>

        <div class="card-body text-center">

            <a asp-action="Edit"
                   asp-route-id="@Model.StudentID"
                   class="btn btn-primary m-2">
                Edit Profile
            </a>

            <a asp-controller="Attendances"
                   asp-action="StudentAttendance"
                   asp-route-id="@Model.StudentID"
                   class="btn btn-success m-2">
                View Attendance
            </a>

            <a asp-controller="Results"
                   asp-action="StudentResults"
                   asp-route-id="@Model.StudentID"
                   class="btn btn-warning m-2">
                View Results
            </a>

            <a class="btn btn-info m-2">
                Fees Details
            </a>

        </div>

    </div>

    <!-- Exam Results -->
    <div class="card shadow mt-3">

        <div class="card-header bg-warning text-dark">
            My Exam Results
        </div>

        <div class="card-body">

            <table class="table table-bordered">

                <thead>
                    <tr>
                        <th>Exam</th>
                        <th>Total</th>
                        <th>Grade</th>
                    </tr>
                </thead>

                <tbody>

                    @if (ViewBag.Results != null && ViewBag.Results.Count > 0)
                    {
                        foreach (var r in ViewBag.Results)
                        {
                            var examId = r.Exam?.ExamID ?? 0;
                            IEnumerable<school_management_system.Models.Mark> marksEnum = (r.Marks as IEnumerable<school_management_system.Models.Mark>) ?? Enumerable.Empty<school_management_system.Models.Mark>();
                            var overallPassed = marksEnum.Any() ? marksEnum.All(m => m.IsPassed) : false;
                            <tr>
                                <td>
                                    <strong>@r.Exam?.ExamName</strong>
                                    <div class="mt-1">
                                        @if(r.IsPublished)
                                        {
                                            if (overallPassed)
                                            {
                                                <span class="badge bg-success">Pass</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Fail</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Not Published</span>
                                        }
                                    </div>
                                </td>
                                <td>@r.TotalMarks</td>
                                <td>
                                    @r.Grade
                                    <div class="mt-1">
                                        <a asp-controller="Reports" asp-action="StudentReportPdf" asp-route-examId="@examId" asp-route-studentId="@Model.StudentID" class="btn btn-sm btn-outline-primary">Download Marksheet (PDF)</a>
                                        <button class="btn btn-sm btn-outline-secondary ms-2" type="button" data-bs-toggle="collapse" data-bs-target="#examCollapse@examId" aria-expanded="false" aria-controls="examCollapse@examId">Details</button>
                                    </div>
                                </td>
                            </tr>
                            <tr class="collapse-row">
                                <td colspan="3" class="p-0">
                                    <div class="collapse" id="examCollapse@examId">
                                        <div class="card card-body">
                                            <table class="table table-sm mb-0">
                                                <thead>
                                                    <tr>
                                                        <th>Subject</th>
                                                        <th>Marks</th>
                                                        <th>Max</th>
                                                        <th>Status</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                            @foreach(var m in marksEnum)
                                                    {
                                                        <tr>
                                                            <td>@m.Subject?.SubjectName</td>
                                                            <td>@m.Marks</td>
                                                            <td>@(m.Subject?.TotalMarks ?? 100)</td>
                                                            <td>
                                                                @if(m.IsPassed)
                                                                {
                                                                    <span class="badge bg-success">Pass</span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="badge bg-danger">Fail</span>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted">
                                No results available
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <!-- Upcoming Exams -->
    <div class="card shadow mt-3">

        <div class="card-header bg-info text-white">
            Upcoming Exams
        </div>

        <div class="card-body">

            <ul>
                @{ var examsList = ViewBag.Exams as IEnumerable<school_management_system.Models.Exam> ?? Enumerable.Empty<school_management_system.Models.Exam>(); }
                @if (examsList.Any())
                {
                    foreach (var exam in examsList.Take(10))
                    {
                        <li>
                            @exam.ExamName -
                            @exam.ExamDate.ToString("dd MMM yyyy")
                        </li>
                    }
                    if(examsList.Count() > 10)
                    {
                        <li><a href="#" id="showMoreExams">Show more...</a></li>
                    }
                }
                else
                {
                    <li class="text-muted">No upcoming exams</li>
                }

            </ul>

        </div>

    </div>

</div>